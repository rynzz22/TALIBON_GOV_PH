# ─── Gemini AI ───────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── App Configuration ───────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase ────────────────────────────────────────────────
# Get your credentials at: https://supabase.com/dashboard
# Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side Supabase (use service role key for backend)
# Project Settings > API > Service Role Key (keep secret!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Payment Gateways (Optional) ─────────────────────────────
# HitPay: https://dashboard.hitpayapp.com/settings/api-keys
HITPAY_API_KEY=your_hitpay_api_key_here
HITPAY_SALT=your_hitpay_salt_here

# Xendit: https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_SECRET_KEY=your_xendit_secret_key_here

# ─── Optional Services ──────────────────────────────────────
# Google Maps: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
